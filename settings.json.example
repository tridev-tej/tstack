{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EXAMPLE_API_KEY": "<YOUR_API_KEY>"
  },
  "permissions": {
    "allow": [
      "Bash(xargs cat:*)",
      "Bash(git pull:*)",
      "Bash(git show:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "auto"
  },
  "enabledMcpjsonServers": [
    "puppeteer",
    "gmail"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/iterm2-claude.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/iterm2-claude.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/iterm2-claude.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/peon-ping/scripts/hook-handle-use.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/iterm2-claude.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/opt/homebrew/bin/bash ~/.claude/statusline/statusline.sh"
  },
  "enabledPlugins": {
    "plugin-dev@claude-code-plugins": true,
    "canvas@claude-canvas": true,
    "claude-delegator@jarrodwatts-claude-delegator": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working on it...",
      "Thinking deeply...",
      "Processing..."
    ]
  }
}
